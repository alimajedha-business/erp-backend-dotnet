{
  "ConnectionStrings": {
    "NGERPDatabase": "Server=.\\sql19;Database=ngerp;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;"
  },
  "JwtSettings": {
    "SecretKey": "your-django-jwt-secret-key-here-must-match-django-settings",
    "Issuer": "your-django-issuer",
    "Audience": "your-django-audience",
    "ValidateIssuer": false,
    "ValidateAudience": false,
    "ValidateLifetime": true
  },
  "DjangoApi": {
    "BaseUrl": "http://localhost:8000"
  },
  "ReverseProxy": {
    "Routes": {
      "django-api-route": {
        "ClusterId": "django-cluster",
        "Match": {
          "Path": "/django-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "dotnet-api-route": {
        "ClusterId": "dotnet-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "django-cluster": {
        "Destinations": {
          "django-destination": {
            "Address": "http://localhost:8000/"
          }
        },
        "HttpClient": {
          "ActivityTimeout": "00:02:00"
        }
      },
      "dotnet-cluster": {
        "Destinations": {
          "dotnet-destination": {
            "Address": "http://localhost:5000/"
          }
        }
      }
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ngerp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
