{
  "ConnectionStrings": {
    "NGERPDatabase": "Data Source=192.168.140.147;Initial Catalog=devg-ngerp;User ID=sa;Password=P@123456;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "SecretKey": "django-insecure-ngerp-secret-key",
    "Issuer": "",
    "Audience": "",
    "ValidateIssuer": false,
    "ValidateAudience": false,
    "ValidateLifetime": true
  },
  "DjangoApi": {
    "BaseUrl": "http://localhost:8000"
  },
  "ReverseProxy": {
    "Routes": {
      "django-api-route": {
        "ClusterId": "django-cluster",
        "Match": {
          "Path": "/django-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "dotnet-api-route": {
        "ClusterId": "dotnet-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "django-cluster": {
        "Destinations": {
          "django-destination": {
            "Address": "http://localhost:8000/"
          }
        }
      },
      "dotnet-cluster": {
        "Destinations": {
          "dotnet-destination": {
            "Address": "http://localhost:5000/"
          }
        }
      }
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ngerp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "NGErp.API"
    }
  }
}