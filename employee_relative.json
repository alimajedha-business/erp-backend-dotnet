    { "name": "FatherName", "type": "string?", "maxLength": 100 },
    { "name": "BirthDate", "type": "DateTime?" },
    { "name": "BirthPlace", "type": "string?", "maxLength": 100 },

    { "name": "MaritalStatusId", "type": "Guid?", "relation": "MaritalStatus" },

